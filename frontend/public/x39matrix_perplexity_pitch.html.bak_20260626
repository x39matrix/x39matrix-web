.info { background: #FFF5F5; border-left: 4px solid #CC0000; padding: 8px 12px; margin: 8px 0; font-size: 9pt; }
.info strong { color: #CC0000; }
table { width: 100%; border-collapse: collapse; margin: 10px 0; font-size: 9pt; }
th { background: #CC0000; color: white; padding: 6px 8px; text-align: left; font-family: 'Courier New', monospace; font-size: 8pt; }
td { padding: 5px 8px; border-bottom: 1px solid #ddd; }
.g { color: #CC0000; font-weight: bold; }
.result-box { border: 2px solid #CC0000; padding: 15px; margin: 15px 0; text-align: center; background: #FFF5F5; }
.result-title { font-size: 14pt; color: #CC0000; font-family: 'Courier New', monospace; font-weight: bold; letter-spacing: 3px; }
.result-detail { font-size: 10pt; color: #333; margin-top: 8px; }
.slide { page-break-before: always; padding: 20px 0; }
.slide-num { font-size: 8pt; color: #CC0000; font-family: 'Courier New', monospace; letter-spacing: 3px; margin-bottom: 10px; }
.slide-title { font-size: 22pt; color: #CC0000; font-family: 'Courier New', monospace; font-weight: bold; margin-bottom: 15px; }
.metric-row { display: flex; justify-content: space-between; margin: 5px 0; }
.big-number { font-size: 28pt; color: #CC0000; font-weight: bold; font-family: 'Courier New', monospace; }
.big-label { font-size: 8pt; color: #888; letter-spacing: 2px; }
ul { margin: 6px 0; padding-left: 16px; }
